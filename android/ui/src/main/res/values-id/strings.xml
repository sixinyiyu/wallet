  <string name="info_watch_wallet_title">Dompet Jam Tangan</string>
  <string name="info_watch_wallet_description">Dompet yang tidak dapat Anda akses, tetapi Anda dapat memantau transaksi dan pergerakannya.</string>
  <string name="info_network_fee_description">Setiap transaksi di jaringan %1$s memerlukan biaya sebesar %2$s yang dibayarkan kepada penambang untuk memproses transaksi Anda, bukan Dompet Permata. Biaya jaringan bervariasi berdasarkan penggunaan jaringan.</string>
  <string name="info_transaction_error_description">Transaksi tidak dapat diselesaikan karena kesalahan, seperti dana tidak mencukupi, input tidak valid, atau penolakan oleh jaringan. Harap tinjau detailnya dan coba lagi.</string>
  <string name="info_transaction_pending_description">Transaksi telah dikirimkan dan sedang menunggu konfirmasi di jaringan. Waktu pemrosesan dapat bervariasi. Silakan periksa kembali untuk pembaruan.</string>
  <string name="info_transaction_success_description">Transaksi telah selesai dan dikonfirmasi di jaringan. Anda dapat meninjau detailnya untuk memverifikasi statusnya.</string>
  <string name="info_lock_time_description">Waktu penguncian, juga dikenal sebagai periode unbonding atau unfreezing, adalah durasi di mana aset yang dipertaruhkan tidak dapat diakses setelah Anda memutuskan untuk melepaskannya.</string>
  <string name="info_price_impact_description">Dampak harga adalah perubahan harga token yang disebabkan oleh ukuran perdagangan Anda. Dampak harga yang lebih tinggi berarti Anda menerima lebih sedikit token karena likuiditas rendah atau ukuran pesanan besar.</string>
  <string name="info_slippage_description">Slippage merujuk pada perbedaan antara harga yang diharapkan dari suatu perdagangan dan harga aktual saat perdagangan itu dieksekusi.</string>
  <string name="info_asset_status_unverified_description">Token yang belum diverifikasi belum diverifikasi secara memadai oleh layanan pihak ketiga yang tepercaya. Token tersebut mungkin muncul di dompet Anda karena airdrop, transfer, atau impor manual.</string>
  <string name="info_asset_status_suspicious_description">Token yang mencurigakan atau spam diidentifikasi sebagai potensi penipuan atau aset berbahaya. Token tersebut mungkin muncul di dompet Anda karena airdrop, transfer, atau impor manual.</string>
  <string name="info_insufficient_network_fee_balance_title">%1$s diperlukan</string>
  <string name="info_insufficient_network_fee_balance_description">Transaksi ini memerlukan %1$s untuk menutupi biaya jaringan yang dibayarkan kepada %2$s penambang, bukan Gem WalletPastikan Anda memiliki cukup %3$s.</string>
  <string name="info_insufficient_balance_title">Saldo Tidak Cukup</string>
  <string name="info_insufficient_balance_description">Anda tidak memiliki cukup %1$s untuk menyelesaikan transaksi ini. Harap isi ulang, terima, atau tukarkan di dompet Anda dan coba lagi.</string>
  <string name="info_account_minimum_balance_title">Saldo minimum</string>
  <string name="info_perpetual_funding_payments_title">Pembayaran Pendanaan</string>
  <string name="info_perpetual_funding_payments_description">Pembayaran pendanaan adalah pembayaran berkala antar pedagang untuk menjaga harga kontrak abadi tetap dekat dengan harga spot aset dasar. Pendanaan positif berarti posisi panjang membayar posisi pendek, sedangkan pendanaan negatif berarti posisi pendek membayar posisi panjang.</string>
  <string name="info_perpetual_funding_rate_title">Pendanaan</string>
  <string name="info_perpetual_funding_rate_description">Tingkat pendanaan menentukan biaya untuk mempertahankan posisi abadi. Ini dihitung setiap jam dan membantu menjaga keseimbangan harga antara kontrak abadi dan harga spot aset yang mendasarinya.</string>
  <string name="info_perpetual_liquidation_price_title">Harga Likuidasi</string>
  <string name="info_perpetual_liquidation_price_description">Harga likuidasi adalah tingkat harga di mana posisi Anda akan ditutup secara otomatis untuk mencegah kerugian lebih lanjut. Ketika harga pasar mencapai level ini, posisi Anda dilikuidasi dan Anda kehilangan margin.</string>
  <string name="info_perpetual_open_interest_title">Minat Terbuka</string>
  <string name="info_perpetual_open_interest_description">Bunga terbuka mewakili nilai total seluruh kontrak abadi yang belum diselesaikan. Ini memberikan wawasan tentang aktivitas pasar dan likuiditas.</string>
  <string name="info_no_quote_description">Tidak dapat mengembalikan kutipan untuk pasangan token yang dipilih, mungkin karena jumlahnya rendah, kurangnya likuiditas, atau keterbatasan teknis.</string>
  <string name="info_stake_reserved_title">Dicadangkan untuk Biaya Jaringan</string>
  <string name="info_stake_reserved_description">Sejumlah kecil dana disimpan di dompet Anda untuk menutupi biaya operasi seperti unstaking atau klaim hadiah.</string>
  <string name="info_stake_apr_description">Tingkat Persentase Tahunan (APR) adalah tingkat imbalan tahunan untuk mempertaruhkan mata uang kripto Anda.</string>
  <string name="info_perpetual_auto_close_description">Tutup posisi Anda secara otomatis pada level harga yang ditentukan. Take Profit mengunci keuntungan, Stop Loss membatasi kerugian.</string>
  <string name="info_fully_diluted_valuation_title">Valuasi Terdilusi Penuh</string>
  <string name="info_fully_diluted_valuation_description">Nilai pasar teoretis jika semua koin beredar. Dihitung sebagai harga dikalikan dengan pasokan maksimum.</string>
  <string name="info_circulating_supply_description">Jumlah koin yang saat ini tersedia dan diperdagangkan di pasar.</string>
  <string name="info_total_supply_description">Jumlah total koin yang ada, termasuk koin yang terkunci atau dicadangkan.</string>
  <string name="info_max_supply_title">Pasokan Maksimum</string>
  <string name="info_max_supply_description">Jumlah maksimum koin yang akan pernah ada.</string>
  <string name="info_perpetual_funding_apr_title">Pendanaan bulan April</string>
  <string name="info_perpetual_funding_apr_description">Tingkat tahunan di mana posisi long membayar posisi short (jika negatif, posisi short membayar posisi long). Tidak ada biaya yang terkait dengan pendanaan, yang merupakan transfer peer-to-peer antar pengguna untuk mendorong harga menuju harga spot.</string>
