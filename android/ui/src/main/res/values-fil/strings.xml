  <string name="info_watch_wallet_title">Watch Wallet</string>
  <string name="info_watch_wallet_description">A wallet that you do not have access to, but you can watch its transactions and movements.</string>
  <string name="info_network_fee_description">Every transaction on the %1$s network requires a fee in %2$s paid to miners to process your transaction, not Gem Wallet. Network fees varies based on network usage.</string>
  <string name="info_transaction_error_description">The transaction could not be completed due to an error, such as insufficient funds, invalid input, or rejection by the network. Please review the details and try again.</string>
  <string name="info_transaction_pending_description">The transaction has been submitted and is awaiting confirmation on the network. Processing times may vary. Please check back for updates.</string>
  <string name="info_transaction_success_description">The transaction has been completed and confirmed on the network. You can review the details to verify its status.</string>
  <string name="info_lock_time_description">Lock time, also known as the unbonding or unfreezing period, is the duration during which staked assets are inaccessible after you decide to unstake them.</string>
  <string name="info_price_impact_description">Price impact is the change in token price caused by your trade size. Higher price impact means you receive fewer tokens due to low liquidity or a large order size.</string>
  <string name="info_slippage_description">Ang slippage ay tumutukoy sa pagkakaiba sa pagitan ng inaasahang presyo ng isang kalakalan at ang aktwal na presyo kung saan ito isinasagawa.</string>
  <string name="info_asset_status_unverified_description">Ang mga hindi na-verify na token ay hindi sapat na na-verify ng mga pinagkakatiwalaang serbisyo ng third-party. Maaaring lumabas ang mga ito sa iyong wallet dahil sa mga airdrop, paglilipat, o manual na pag-import.</string>
  <string name="info_asset_status_suspicious_description">Ang mga kahina-hinalang token o spam ay tinutukoy bilang mga potensyal na scam o mapaminsalang asset. Maaaring lumabas ang mga ito sa iyong wallet dahil sa mga airdrop, paglilipat, o manual na pag-import.</string>
  <string name="info_insufficient_network_fee_balance_title">%1$s kinakailangan</string>
  <string name="info_insufficient_network_fee_balance_description">Ang transaksyong ito ay nangangailangan ng %1$s para mabayaran ang bayad sa network na ibinayad sa %2$s mga minero, hindi Gem WalletTiyaking mayroon kang sapat %3$s.</string>
  <string name="info_insufficient_balance_title">Hindi Sapat na Balanse</string>
  <string name="info_insufficient_balance_description">Wala kang sapat na %1$s upang makumpleto ang transaksyong ito. Mangyaring mag-top up, tumanggap, o magpalit sa iyong wallet at subukang muli.</string>
  <string name="info_account_minimum_balance_title">Minimum na balanse</string>
  <string name="info_perpetual_funding_payments_title">Funding Payments</string>
  <string name="info_perpetual_funding_payments_description">Funding payments are periodic payments between traders to keep the perpetual contract price close to the underlying asset\'s spot price. Positive funding means long positions pay short positions, while negative funding means short positions pay long positions.</string>
  <string name="info_perpetual_funding_rate_title">Funding</string>
  <string name="info_perpetual_funding_rate_description">The funding rate determines the cost of holding a perpetual position. It is calculated hourly and helps maintain price equilibrium between the perpetual contract and the underlying asset\'s spot price.</string>
  <string name="info_perpetual_liquidation_price_title">Presyo ng Liquidation</string>
  <string name="info_perpetual_liquidation_price_description">The liquidation price is the price level at which your position will be automatically closed to prevent further losses. When the market price reaches this level, your position is liquidated and you lose your margin.</string>
  <string name="info_perpetual_open_interest_title">Open Interest</string>
  <string name="info_perpetual_open_interest_description">Open interest represents the total value of all outstanding perpetual contracts that have not been settled. It provides insight into market activity and liquidity.</string>
  <string name="info_no_quote_description">Hindi maibalik ang isang quote para sa napiling pares ng token, posibleng dahil sa mababang halaga, kakulangan ng pagkatubig, o mga teknikal na limitasyon.</string>
  <string name="info_stake_reserved_title">Nakalaan para sa Bayad ng Network</string>
  <string name="info_stake_reserved_description">May maliit na halaga ang nananatili sa iyong wallet para mabayaran ang mga bayarin para sa mga operasyon tulad ng pag-unstaking o pag-claim ng mga reward.</string>
  <string name="info_stake_apr_description">Ang Annual Percentage Rate (APR) ay ang taunang reward rate para sa staking ng iyong cryptocurrency.</string>
  <string name="info_perpetual_auto_close_description">Awtomatikong isara ang iyong posisyon sa nakatakdang antas ng presyo. Kumuha ng Profit lock sa mga nadagdag, Stop Loss limitahan pagkalugi.</string>
  <string name="info_fully_diluted_valuation_title">Ganap na Diluted na Pagtatasa</string>
  <string name="info_fully_diluted_valuation_description">Ang teoretikal na halaga sa pamilihan kung lahat ng barya ay nasa sirkulasyon. Kinakalkula bilang presyo na pinarami sa pinakamataas na suplay.</string>
  <string name="info_circulating_supply_description">Ang bilang ng mga barya na kasalukuyang magagamit at ipinagbibili sa merkado.</string>
  <string name="info_total_supply_description">Ang kabuuang bilang ng mga barya na umiiral, kabilang ang mga naka-lock o nakareserbang barya.</string>
  <string name="info_max_supply_title">Pinakamataas na Suplay</string>
  <string name="info_max_supply_description">Ang pinakamataas na bilang ng mga barya na iiral kailanman.</string>
  <string name="info_perpetual_funding_apr_title">Funding APR</string>
  <string name="info_perpetual_funding_apr_description">The annualized rate at which longs pay shorts (if negative, shorts pay longs). There are no fees associated with funding, which is a peer-to-peer transfer between users to push prices towards the spot price.</string>
