  <string name="info_network_fee_title">Ada ya Mtandao</string>
  <string name="info_watch_wallet_title">Tazama Wallet</string>
  <string name="info_watch_wallet_description">Mkoba ambao huna ufikiaji, lakini unaweza kutazama shughuli na harakati zake.</string>
  <string name="info_network_fee_description">Kila muamala kwenye mtandao wa %1$s unahitaji ada ya %2$s kulipwa kwa wachimbaji ili kushughulikia muamala wako, si Gem Wallet. Ada za mtandao hutofautiana kulingana na matumizi ya mtandao.</string>
  <string name="info_transaction_error_description">Muamala haukuweza kukamilika kwa sababu ya hitilafu, kama vile uhaba wa fedha, ingizo batili au kukataliwa na mtandao. Tafadhali kagua maelezo na ujaribu tena.</string>
  <string name="info_transaction_pending_description">Muamala umewasilishwa na unasubiri uthibitisho kwenye mtandao. Nyakati za usindikaji zinaweza kutofautiana. Tafadhali angalia tena kwa sasisho.</string>
  <string name="info_transaction_success_description">Muamala umekamilika na kuthibitishwa kwenye mtandao. Unaweza kukagua maelezo ili kuthibitisha hali yake.</string>
  <string name="info_lock_time_description">Muda wa kufunga, unaojulikana pia kama kipindi cha kuunganisha au kufungia, ni muda ambao mali zilizowekwa kwenye hisa haziwezi kufikiwa baada ya kuamua kuziondoa.</string>
  <string name="info_price_impact_description">Athari ya bei ni mabadiliko ya bei ya tokeni yanayosababishwa na ukubwa wa biashara yako. Athari ya bei ya juu inamaanisha unapokea tokeni chache kutokana na ukwasi mdogo au ukubwa mkubwa wa agizo.</string>
  <string name="info_slippage_description">Slippage inarejelea tofauti kati ya bei inayotarajiwa ya biashara na bei halisi ambayo inatekelezwa.</string>
  <string name="info_asset_status_unverified_description">Tokeni ambazo hazijathibitishwa hazijathibitishwa vya kutosha na huduma zinazoaminika za wahusika wengine. Huenda zikaonekana kwenye mkoba wako kwa sababu ya matone ya hewa, uhamisho, au uagizaji wa mikono.</string>
  <string name="info_asset_status_suspicious_description">Tokeni zinazotiliwa shaka au taka zinatambuliwa kuwa ulaghai au mali hatari. Huenda zikaonekana kwenye mkoba wako kwa sababu ya matone ya hewa, uhamisho, au uagizaji wa mikono.</string>
  <string name="info_insufficient_network_fee_balance_title">%1$s inahitajika</string>
  <string name="info_insufficient_network_fee_balance_description">Muamala huu unahitaji %1$s ili kufidia ada ya mtandao iliyolipwa kwa %2$s wachimbaji, si Gem WalletHakikisha una vya kutosha %3$s.</string>
  <string name="info_insufficient_balance_title">Mizani isiyotosha</string>
  <string name="info_insufficient_balance_description">Huna %1$s ya kutosha kukamilisha muamala huu. Tafadhali jaza, pokea, au ubadilishe pochi yako na ujaribu tena.</string>
  <string name="info_account_minimum_balance_title">Kiwango cha chini cha usawa</string>
  <string name="info_perpetual_funding_payments_title">Malipo ya Ufadhili</string>
  <string name="info_perpetual_funding_payments_description">Malipo ya ufadhili ni malipo ya mara kwa mara kati ya wafanyabiashara ili kuweka bei ya kudumu ya mkataba karibu na bei ya msingi ya mali. Ufadhili mzuri unamaanisha nafasi ndefu kulipa nafasi fupi, wakati ufadhili hasi unamaanisha nafasi fupi kulipa nafasi ndefu.</string>
  <string name="info_perpetual_funding_rate_title">Ufadhili</string>
  <string name="info_perpetual_funding_rate_description">Kiwango cha ufadhili huamua gharama ya kushikilia nafasi ya kudumu. Hukokotolewa kila saa na husaidia kudumisha usawa wa bei kati ya mkataba wa kudumu na bei ya msingi ya kipengee.</string>
  <string name="info_perpetual_liquidation_price_title">Bei ya Kukomesha</string>
  <string name="info_perpetual_liquidation_price_description">Bei ya kufilisi ni kiwango cha bei ambapo nafasi yako itafungwa kiotomatiki ili kuzuia hasara zaidi. Wakati bei ya soko inafikia kiwango hiki, nafasi yako inafutwa na unapoteza kiasi chako.</string>
  <string name="info_perpetual_open_interest_title">Fungua Maslahi</string>
  <string name="info_perpetual_open_interest_description">Riba ya wazi inawakilisha jumla ya thamani ya kandarasi zote za kudumu ambazo hazijatatuliwa. Inatoa maarifa juu ya shughuli za soko na ukwasi.</string>
  <string name="info_no_quote_description">Haikuweza kurejesha nukuu kwa jozi ya tokeni iliyochaguliwa, labda kwa sababu ya kiasi kidogo, ukosefu wa ukwasi, au vikwazo vya kiufundi.</string>
  <string name="info_stake_reserved_title">Imehifadhiwa kwa Ada ya Mtandao</string>
  <string name="info_stake_reserved_description">Kiasi kidogo husalia kwenye mkoba wako ili kulipia ada za shughuli kama vile kutoweka au kudai zawadi.</string>
  <string name="info_stake_apr_description">Kiwango cha Asilimia cha Mwaka (APR) ni kiwango cha tuzo cha kila mwaka cha kuweka sarafu yako ya cryptocurrency.</string>
  <string name="info_perpetual_auto_close_description">Funga msimamo wako kiotomatiki katika viwango vya bei vilivyowekwa. Chukua kufuli za Faida katika faida, Stop Loss mipaka hasara.</string>
  <string name="info_fully_diluted_valuation_title">Thamani Iliyopunguzwa Kikamilifu</string>
  <string name="info_fully_diluted_valuation_description">Thamani ya kinadharia ya soko ikiwa sarafu zote zilikuwa zikitumika. Imehesabiwa kama bei ikizidishwa na usambazaji wa juu zaidi.</string>
  <string name="info_circulating_supply_description">Idadi ya sarafu zinazopatikana sasa na zinazouzwa sokoni.</string>
  <string name="info_total_supply_description">Jumla ya sarafu zilizopo, ikijumuisha sarafu zilizofungwa au zilizohifadhiwa.</string>
  <string name="info_max_supply_title">Ugavi wa Juu Zaidi</string>
  <string name="info_max_supply_description">Idadi ya juu zaidi ya sarafu zitakazokuwepo.</string>
  <string name="info_perpetual_funding_apr_title">Ufadhili wa APR</string>
  <string name="info_perpetual_funding_apr_description">Kiwango cha kila mwaka ambacho urefu hulipa kaptula (ikiwa hasi, kaptula hulipa muda mrefu). Hakuna ada zinazohusishwa na ufadhili, ambao ni uhamishaji kati ya watumiaji kati ya watumiaji ili kusukuma bei kuelekea bei inayotarajiwa.</string>
