  <string name="info_watch_wallet_description">ایک پرس جس تک آپ کی رسائی نہیں ہے، لیکن آپ اس کے لین دین اور نقل و حرکت دیکھ سکتے ہیں۔</string>
  <string name="info_network_fee_description">%1$s نیٹ ورک پر ہر ٹرانزیکشن کے لیے %2$s میں فیس کی ضرورت ہوتی ہے جو کان کنوں کو آپ کے لین دین پر کارروائی کرنے کے لیے ادا کی جاتی ہے، Gem Wallet کی نہیں۔ نیٹ ورک فیس نیٹ ورک کے استعمال کی بنیاد پر مختلف ہوتی ہے۔</string>
  <string name="info_transaction_error_description">لین دین ایک خرابی کی وجہ سے مکمل نہیں ہو سکا، جیسے کہ ناکافی فنڈز، غلط ان پٹ، یا نیٹ ورک کی طرف سے مسترد۔ براہ کرم تفصیلات کا جائزہ لیں اور دوبارہ کوشش کریں۔</string>
  <string name="info_transaction_pending_description">لین دین جمع کر دیا گیا ہے اور نیٹ ورک پر تصدیق کا انتظار کر رہا ہے۔ پروسیسنگ کے اوقات مختلف ہو سکتے ہیں۔ براہ کرم اپ ڈیٹس کے لیے دوبارہ چیک کریں۔</string>
  <string name="info_transaction_success_description">لین دین مکمل ہو چکا ہے اور نیٹ ورک پر اس کی تصدیق ہو چکی ہے۔ آپ اس کی حیثیت کی تصدیق کے لیے تفصیلات کا جائزہ لے سکتے ہیں۔</string>
  <string name="info_lock_time_description">لاک ٹائم، جسے ان بانڈنگ یا غیر منجمد کرنے کا دورانیہ بھی کہا جاتا ہے، وہ دورانیہ ہے جس کے دوران داؤ پر لگے اثاثے ناقابل رسائی ہوتے ہیں جب آپ ان کو ہٹانے کا فیصلہ کرتے ہیں۔</string>
  <string name="info_price_impact_description">قیمت کا اثر آپ کے تجارتی سائز کی وجہ سے ٹوکن کی قیمت میں تبدیلی ہے۔ زیادہ قیمت کے اثر کا مطلب ہے کہ آپ کو کم لیکویڈیٹی یا آرڈر کے بڑے سائز کی وجہ سے کم ٹوکن ملتے ہیں۔</string>
  <string name="info_slippage_description">Slippage سے مراد تجارت کی متوقع قیمت اور اصل قیمت کے درمیان فرق ہے جس پر اس پر عمل درآمد ہوتا ہے۔</string>
  <string name="info_asset_status_unverified_description">غیر تصدیق شدہ ٹوکنز کی بھروسہ مند فریق ثالث خدمات کے ذریعہ کافی تصدیق نہیں کی گئی ہے۔ وہ ایئر ڈراپس، ٹرانسفرز، یا دستی درآمدات کی وجہ سے آپ کے بٹوے میں ظاہر ہو سکتے ہیں۔</string>
  <string name="info_asset_status_suspicious_description">مشکوک یا سپیم ٹوکنز کی شناخت ممکنہ گھوٹالوں یا نقصان دہ اثاثوں کے طور پر کی جاتی ہے۔ وہ ایئر ڈراپس، ٹرانسفرز، یا دستی درآمدات کی وجہ سے آپ کے بٹوے میں ظاہر ہو سکتے ہیں۔</string>
  <string name="info_insufficient_network_fee_balance_title">%1$s درکار ہے۔</string>
  <string name="info_insufficient_network_fee_balance_description">اس لین دین کی ضرورت ہے۔ %1$s نیٹ ورک کی فیس کو پورا کرنے کے لیے %2$s کان کنوں، نہیں Gem Wallet. یقینی بنائیں کہ آپ کے پاس کافی ہے۔ %3$s.</string>
  <string name="info_insufficient_balance_title">ناکافی بیلنس</string>
  <string name="info_insufficient_balance_description">آپ کے پاس اس لین دین کو مکمل کرنے کے لیے کافی %1$s نہیں ہے۔ براہ کرم اپنے بٹوے میں ٹاپ اپ کریں، وصول کریں یا تبدیل کریں اور دوبارہ کوشش کریں۔</string>
  <string name="info_account_minimum_balance_title">کم از کم بیلنس</string>
  <string name="info_perpetual_funding_payments_title">فنڈز کی ادائیگی</string>
  <string name="info_perpetual_funding_payments_description">فنڈنگ ​​کی ادائیگیاں تاجروں کے درمیان متواتر ادائیگیاں ہوتی ہیں تاکہ دائمی معاہدے کی قیمت کو بنیادی اثاثہ کی جگہ کی قیمت کے قریب رکھا جا سکے۔ مثبت فنڈنگ ​​کا مطلب ہے لانگ پوزیشنز شارٹ پوزیشنز ادا کرتی ہیں، جبکہ منفی فنڈنگ ​​کا مطلب ہے کہ شارٹ پوزیشنز لانگ پوزیشنز ادا کرتی ہیں۔</string>
  <string name="info_perpetual_funding_rate_title">فنڈنگ</string>
  <string name="info_perpetual_funding_rate_description">فنڈنگ کی شرح مستقل پوزیشن کے انعقاد کی لاگت کا تعین کرتی ہے۔ یہ فی گھنٹہ حساب کیا جاتا ہے اور دائمی معاہدے اور بنیادی اثاثہ کی جگہ کی قیمت کے درمیان قیمت کے توازن کو برقرار رکھنے میں مدد کرتا ہے۔</string>
  <string name="info_perpetual_liquidation_price_title">لیکویڈیشن کی قیمت</string>
  <string name="info_perpetual_liquidation_price_description">لیکویڈیشن پرائس قیمت کی سطح ہے جس پر مزید نقصانات کو روکنے کے لیے آپ کی پوزیشن خود بخود بند ہو جائے گی۔ جب مارکیٹ کی قیمت اس سطح تک پہنچ جاتی ہے، تو آپ کی پوزیشن ختم ہو جاتی ہے اور آپ اپنا مارجن کھو دیتے ہیں۔</string>
  <string name="info_perpetual_open_interest_title">کھلی دلچسپی</string>
  <string name="info_perpetual_open_interest_description">کھلی دلچسپی ان تمام بقایا دائمی معاہدوں کی کل قیمت کی نمائندگی کرتی ہے جن کا تصفیہ نہیں ہوا ہے۔ یہ مارکیٹ کی سرگرمی اور لیکویڈیٹی کے بارے میں بصیرت فراہم کرتا ہے۔</string>
  <string name="info_no_quote_description">ممکنہ طور پر کم رقم، لیکویڈیٹی کی کمی، یا تکنیکی حدود کی وجہ سے منتخب کردہ ٹوکن جوڑے کے لیے کوئی اقتباس واپس کرنے سے قاصر ہے۔</string>
  <string name="info_stake_reserved_title">نیٹ ورک فیس کے لیے محفوظ ہے</string>
  <string name="info_stake_reserved_description">ایک چھوٹی سی رقم آپ کے بٹوے میں رہ جاتی ہے تاکہ ان کارروائیوں کے لیے فیس کو پورا کیا جا سکے جیسے کہ انعامات کا دعوی کرنا یا دعوی کرنا۔</string>
  <string name="info_stake_apr_description">سالانہ فیصدی شرح (APR) آپ کی کریپٹو کرنسی کو داغدار کرنے کے لیے سالانہ انعام کی شرح ہے۔</string>
  <string name="info_perpetual_auto_close_description">اپنی پوزیشن کو سیٹ قیمت کی سطحوں پر خودکار طور پر بند کریں۔ منافع میں منافع کے تالے لیں، نقصان کو روکیں نقصانات کو محدود کریں۔</string>
  <string name="info_fully_diluted_valuation_title">مکمل طور پر کمزور تشخیص</string>
  <string name="info_fully_diluted_valuation_description">نظریاتی مارکیٹ کی قیمت اگر تمام سکے گردش میں تھے۔ قیمت کو زیادہ سے زیادہ سپلائی سے ضرب کے حساب سے شمار کیا جاتا ہے۔</string>
  <string name="info_circulating_supply_description">سککوں کی تعداد جو فی الحال دستیاب ہے اور مارکیٹ میں تجارت کر رہے ہیں۔</string>
