  <string name="sell_title">Bán %1$s</string>
  <string name="info_network_fee_title">Phí mạng</string>
  <string name="info_watch_wallet_title">Ví đồng hồ</string>
  <string name="info_watch_wallet_description">Một ví mà bạn không thể truy cập nhưng bạn có thể theo dõi các giao dịch và biến động của nó.</string>
  <string name="info_network_fee_description">Mọi giao dịch trên mạng %1$s đều yêu cầu một khoản phí bằng %2$s trả cho người khai thác để xử lý giao dịch của bạn, không phải Ví Gem. Phí mạng thay đổi tùy theo mức sử dụng mạng.</string>
  <string name="info_transaction_error_description">Giao dịch không thể hoàn tất do lỗi, chẳng hạn như không đủ tiền, đầu vào không hợp lệ hoặc bị mạng từ chối. Vui lòng xem lại chi tiết và thử lại.</string>
  <string name="info_transaction_pending_description">Giao dịch đã được gửi và đang chờ xác nhận trên mạng. Thời gian xử lý có thể thay đổi. Vui lòng kiểm tra lại để cập nhật.</string>
  <string name="info_transaction_success_description">Giao dịch đã hoàn tất và được xác nhận trên mạng. Bạn có thể xem lại thông tin chi tiết để xác minh trạng thái của giao dịch.</string>
  <string name="info_lock_time_description">Thời gian khóa, còn được gọi là thời gian hủy liên kết hoặc hủy đóng băng, là khoảng thời gian mà tài sản đã đặt cược không thể truy cập được sau khi bạn quyết định hủy đặt cược chúng.</string>
  <string name="info_price_impact_description">Tác động giá là sự thay đổi về giá token do quy mô giao dịch của bạn gây ra. Tác động giá cao hơn có nghĩa là bạn nhận được ít token hơn do tính thanh khoản thấp hoặc quy mô lệnh lớn.</string>
  <string name="info_slippage_description">Trượt giá là sự chênh lệch giữa giá dự kiến của một giao dịch và giá thực tế khi giao dịch đó được thực hiện.</string>
  <string name="info_asset_status_unverified_description">Các mã thông báo chưa được xác minh chưa được xác minh đầy đủ bởi các dịch vụ của bên thứ ba đáng tin cậy. Chúng có thể xuất hiện trong ví của bạn do airdrop, chuyển khoản hoặc nhập thủ công.</string>
  <string name="info_asset_status_suspicious_description">Mã thông báo đáng ngờ hoặc thư rác được xác định là lừa đảo tiềm ẩn hoặc tài sản có hại. Chúng có thể xuất hiện trong ví của bạn do airdrop, chuyển khoản hoặc nhập thủ công.</string>
  <string name="info_insufficient_network_fee_balance_title">%1$s bắt buộc</string>
  <string name="info_insufficient_network_fee_balance_description">Giao dịch này yêu cầu %1$s để trang trải phí mạng đã trả cho %2$s thợ mỏ, không phải Gem WalletHãy đảm bảo bạn có đủ %3$s.</string>
  <string name="info_insufficient_balance_title">Số dư không đủ</string>
  <string name="info_insufficient_balance_description">Bạn không có đủ %1$s để hoàn tất giao dịch này. Vui lòng nạp tiền, nhận hoặc đổi trong ví của bạn và thử lại.</string>
  <string name="info_account_minimum_balance_title">Số dư tối thiểu</string>
  <string name="info_perpetual_funding_payments_title">Thanh toán tài trợ</string>
  <string name="info_perpetual_funding_payments_description">Thanh toán cấp vốn là khoản thanh toán định kỳ giữa các nhà giao dịch để giữ giá hợp đồng vĩnh viễn gần với giá giao ngay của tài sản cơ bản. Nguồn vốn dương có nghĩa là các vị thế mua sẽ trả cho các vị thế bán, trong khi nguồn vốn âm có nghĩa là các vị thế bán sẽ trả cho các vị thế mua.</string>
  <string name="info_perpetual_funding_rate_title">Tài trợ</string>
  <string name="info_perpetual_funding_rate_description">Tỷ lệ tài trợ xác định chi phí để giữ một vị thế vĩnh viễn. Nó được tính toán hàng giờ và giúp duy trì sự cân bằng giá giữa hợp đồng vĩnh viễn và giá giao ngay của tài sản cơ bản.</string>
  <string name="info_perpetual_liquidation_price_title">Giá thanh lý</string>
  <string name="info_perpetual_liquidation_price_description">Giá thanh lý là mức giá mà tại đó vị thế của bạn sẽ tự động bị đóng để tránh thua lỗ thêm. Khi giá thị trường đạt đến mức này, vị thế của bạn sẽ bị thanh lý và bạn mất tiền ký quỹ.</string>
  <string name="info_perpetual_open_interest_title">Lãi suất mở</string>
  <string name="info_perpetual_open_interest_description">Lãi suất mở thể hiện tổng giá trị của tất cả các hợp đồng vĩnh viễn chưa thanh toán chưa được thanh toán. Nó cung cấp cái nhìn sâu sắc về hoạt động thị trường và tính thanh khoản.</string>
  <string name="info_no_quote_description">Không thể trả về báo giá cho cặp mã thông báo đã chọn, có thể do số lượng thấp, thiếu thanh khoản hoặc hạn chế về mặt kỹ thuật.</string>
  <string name="info_stake_reserved_title">Dành riêng cho Phí mạng</string>
  <string name="info_stake_reserved_description">Một số tiền nhỏ sẽ được giữ lại trong ví của bạn để trang trải phí cho các hoạt động như hủy đặt cọc hoặc nhận phần thưởng.</string>
  <string name="info_stake_apr_description">Tỷ lệ phần trăm hàng năm (APR) là tỷ lệ phần thưởng hàng năm cho việc đặt cược tiền điện tử của bạn.</string>
  <string name="info_perpetual_auto_close_description">Tự động đóng vị thế của bạn ở mức giá đã đặt. Chốt lời khóa lợi nhuận, Cắt lỗ hạn chế thua lỗ.</string>
  <string name="info_fully_diluted_valuation_title">Định giá sau khi pha loãng hoàn toàn</string>
  <string name="info_fully_diluted_valuation_description">Giá trị thị trường lý thuyết nếu tất cả các đồng tiền đều được lưu thông. Được tính bằng giá nhân với nguồn cung tối đa.</string>
  <string name="info_circulating_supply_description">Số lượng tiền điện tử hiện có và đang được giao dịch trên thị trường.</string>
  <string name="info_total_supply_description">Tổng số lượng tiền xu hiện có, bao gồm cả tiền xu bị khóa hoặc được giữ lại.</string>
  <string name="info_max_supply_title">Cung cấp tối đa</string>
  <string name="info_max_supply_description">Số lượng tối đa các đồng xu sẽ từng tồn tại.</string>
