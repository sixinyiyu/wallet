  <string name="warnings_multi_signature_blocked">Overfør ikke penge til denne %1$s Multi-Signatur-pung, medmindre du er sikker på, at du kontrollerer de private nøgler. Undladelse af at gøre det kan udsætte dig for svindel, og du kan permanent miste dine aktiver.</string>
  <string name="sell_title">Sælg %1$s</string>
  <string name="info_network_fee_title">Netværksgebyr</string>
  <string name="info_watch_wallet_title">Watch Wallet</string>
  <string name="info_watch_wallet_description">En pung, som du ikke har adgang til, men du kan se dens transaktioner og bevægelser.</string>
  <string name="info_network_fee_description">Hver transaktion på %1$s netværket kræver et gebyr i %2$s betalt til minearbejdere for at behandle din transaktion, ikke Gem Wallet. Netværksgebyrer varierer afhængigt af netværksbrug.</string>
  <string name="info_transaction_error_description">Transaktionen kunne ikke gennemføres på grund af en fejl, såsom utilstrækkelige midler, ugyldigt input eller afvisning af netværket. Gennemgå venligst detaljerne og prøv igen.</string>
  <string name="info_transaction_pending_description">Transaktionen er blevet indsendt og afventer bekræftelse på netværket. Behandlingstiderne kan variere. Kom venligst tilbage for opdateringer.</string>
  <string name="info_transaction_success_description">Transaktionen er gennemført og bekræftet på netværket. Du kan gennemgå detaljerne for at bekræfte dens status.</string>
  <string name="info_lock_time_description">Låsetid, også kendt som ophævelses- eller frigørelsesperioden, er den varighed, hvori satsede aktiver er utilgængelige, efter at du beslutter dig for at ophæve dem.</string>
  <string name="info_price_impact_description">Prispåvirkning er ændringen i tokenpris forårsaget af din handelsstørrelse. Større prispåvirkning betyder, at du modtager færre tokens på grund af lav likviditet eller en stor ordrestørrelse.</string>
  <string name="info_slippage_description">Slippage refererer til forskellen mellem den forventede pris på en handel og den faktiske pris, den udføres til.</string>
  <string name="info_asset_status_unverified_description">Ubekræftede tokens er ikke blevet tilstrækkeligt verificeret af betroede tredjepartstjenester. De kan dukke op i din wallet på grund af airdrops, overførsler eller manuelle importer.</string>
  <string name="info_asset_status_suspicious_description">Mistænkelige eller spam-tokens identificeres som potentielle svindelnumre eller skadelige aktiver. De kan dukke op i din wallet på grund af airdrops, overførsler eller manuelle importer.</string>
  <string name="info_insufficient_network_fee_balance_title">%1$s påkrævet</string>
  <string name="info_insufficient_network_fee_balance_description">Denne transaktion kræver %1$s til dækning af det betalte netværksgebyr %2$s minearbejdere, ikke Gem WalletSørg for at du har nok %3$s.</string>
  <string name="info_insufficient_balance_title">Utilstrækkelig saldo</string>
  <string name="info_insufficient_balance_description">Du har ikke nok %1$s til at gennemføre denne transaktion. Tank op, modtag eller veksle i din wallet, og prøv igen.</string>
  <string name="info_account_minimum_balance_title">Minimumsaldo</string>
  <string name="info_perpetual_funding_payments_title">Finansieringsbetalinger</string>
  <string name="info_perpetual_funding_payments_description">Finansieringsbetalinger er periodiske betalinger mellem handlende for at holde den evige kontraktpris tæt på det underliggende aktivs spotpris. Positiv finansiering betyder, at lange positioner betaler korte positioner, mens negativ funding betyder, at korte positioner betaler lange positioner.</string>
  <string name="info_perpetual_funding_rate_title">Finansiering</string>
  <string name="info_perpetual_funding_rate_description">Funding rate bestemmer omkostningerne ved at holde en evig position. Den beregnes hver time og hjælper med at opretholde prisligevægten mellem den evige kontrakt og det underliggende aktivs spotpris.</string>
  <string name="info_perpetual_liquidation_price_title">Likvidationspris</string>
  <string name="info_perpetual_liquidation_price_description">Likvidationsprisen er det prisniveau, hvor din position automatisk lukkes for at forhindre yderligere tab. Når markedsprisen når dette niveau, er din position likvideret, og du mister din margin.</string>
  <string name="info_perpetual_open_interest_title">Åben interesse</string>
  <string name="info_perpetual_open_interest_description">Åben rente repræsenterer den samlede værdi af alle udestående evige kontrakter, der ikke er blevet afviklet. Det giver indsigt i markedsaktivitet og likviditet.</string>
  <string name="info_no_quote_description">Kan ikke returnere en pris for det valgte tokenpar, muligvis på grund af lavt beløb, manglende likviditet eller tekniske begrænsninger.</string>
  <string name="info_stake_reserved_title">Reserveret til netværksgebyr</string>
  <string name="info_stake_reserved_description">Et lille beløb forbliver i din pung til at dække gebyrer for operationer som at fjerne indsatser eller gøre krav på belønninger.</string>
  <string name="info_stake_apr_description">Årlig procentsats (ÅOP) er den årlige belønningssats for at satse din kryptovaluta.</string>
  <string name="info_perpetual_auto_close_description">Luk automatisk din position ved fastsatte prisniveauer. Take Profit låser gevinster, Stop Loss begrænser tab.</string>
  <string name="info_fully_diluted_valuation_title">Fuldt udvandet værdiansættelse</string>
  <string name="info_fully_diluted_valuation_description">Den teoretiske markedsværdi, hvis alle mønter var i omløb. Beregnet som prisen ganget med det maksimale udbud.</string>
  <string name="info_circulating_supply_description">Antallet af tilgængelige og handlede mønter på markedet i øjeblikket.</string>
  <string name="info_total_supply_description">Det samlede antal mønter, der findes, inklusive låste eller reserverede mønter.</string>
  <string name="info_max_supply_title">Maks. forsyning</string>
  <string name="info_max_supply_description">Det maksimale antal mønter, der nogensinde vil eksistere.</string>
  <string name="info_perpetual_funding_apr_title">Finansiering ÅOP</string>
  <string name="info_perpetual_funding_apr_description">Den årlige sats, hvormed longs betaler shorts (hvis negative, shorts pay longs). Der er ingen gebyrer forbundet med finansiering, som er en peer-to-peer-overførsel mellem brugere for at presse priserne mod spotprisen.</string>
