  <string name="warnings_multi_signature_blocked">Jangan pindahkan dana ke %1$s dompet Berbilang Tandatangan ini melainkan anda pasti anda mengawal kunci peribadi. Kegagalan berbuat demikian boleh mendedahkan anda kepada penipuan dan anda mungkin kehilangan aset anda secara kekal.</string>
  <string name="sell_title">Jual %1$s</string>
  <string name="info_network_fee_title">Yuran Rangkaian</string>
  <string name="info_watch_wallet_title">Tonton Wallet</string>
  <string name="info_watch_wallet_description">Dompet yang anda tidak mempunyai akses, tetapi anda boleh menonton transaksi dan pergerakannya.</string>
  <string name="info_network_fee_description">Setiap transaksi pada rangkaian %1$s memerlukan bayaran dalam %2$s dibayar kepada pelombong untuk memproses transaksi anda, bukan Dompet Permata. Yuran rangkaian berbeza-beza berdasarkan penggunaan rangkaian.</string>
  <string name="info_transaction_error_description">Urus niaga tidak dapat diselesaikan kerana ralat, seperti dana tidak mencukupi, input tidak sah atau penolakan oleh rangkaian. Sila semak butiran dan cuba lagi.</string>
  <string name="info_transaction_pending_description">Urus niaga telah diserahkan dan sedang menunggu pengesahan pada rangkaian. Masa pemprosesan mungkin berbeza-beza. Sila semak semula untuk kemas kini.</string>
  <string name="info_transaction_success_description">Urus niaga telah selesai dan disahkan pada rangkaian. Anda boleh menyemak butiran untuk mengesahkan statusnya.</string>
  <string name="info_lock_time_description">Masa kunci, juga dikenali sebagai tempoh nyah ikatan atau nyahbeku, ialah tempoh di mana aset dipertaruhkan tidak boleh diakses selepas anda memutuskan untuk menyahtaruhnya.</string>
  <string name="info_price_impact_description">Kesan harga ialah perubahan dalam harga token yang disebabkan oleh saiz dagangan anda. Kesan harga yang lebih tinggi bermakna anda menerima lebih sedikit token disebabkan kecairan yang rendah atau saiz pesanan yang besar.</string>
  <string name="info_slippage_description">Slippage merujuk kepada perbezaan antara harga jangkaan perdagangan dan harga sebenar di mana ia dilaksanakan.</string>
  <string name="info_asset_status_unverified_description">Token yang tidak disahkan belum disahkan dengan secukupnya oleh perkhidmatan pihak ketiga yang dipercayai. Ia mungkin muncul dalam dompet anda disebabkan oleh airdrop, pemindahan atau import manual.</string>
  <string name="info_asset_status_suspicious_description">Token yang mencurigakan atau spam dikenal pasti sebagai potensi penipuan atau aset berbahaya. Ia mungkin muncul dalam dompet anda disebabkan oleh airdrop, pemindahan atau import manual.</string>
  <string name="info_insufficient_network_fee_balance_title">%1$s diperlukan</string>
  <string name="info_insufficient_network_fee_balance_description">Transaksi ini memerlukan %1$s untuk menampung yuran rangkaian yang dibayar kepada %2$s pelombong, bukan Gem WalletPastikan anda mempunyai cukup %3$s.</string>
  <string name="info_insufficient_balance_title">Baki Tidak Mencukupi</string>
  <string name="info_insufficient_balance_description">Anda tidak mempunyai cukup %1$s untuk menyelesaikan transaksi ini. Sila tambah nilai, terima atau tukar dalam dompet anda dan cuba lagi.</string>
  <string name="info_account_minimum_balance_title">Baki minimum</string>
  <string name="info_perpetual_funding_payments_title">Pembayaran Pembiayaan</string>
  <string name="info_perpetual_funding_payments_description">Pembayaran pembiayaan ialah pembayaran berkala antara pedagang untuk memastikan harga kontrak kekal hampir dengan harga spot aset pendasar. Pembiayaan positif bermakna kedudukan panjang membayar kedudukan pendek, manakala pembiayaan negatif bermakna kedudukan pendek membayar kedudukan panjang.</string>
  <string name="info_perpetual_funding_rate_title">Pembiayaan</string>
  <string name="info_perpetual_funding_rate_description">Kadar pembiayaan menentukan kos memegang jawatan kekal. Ia dikira setiap jam dan membantu mengekalkan keseimbangan harga antara kontrak kekal dan harga spot aset pendasar.</string>
  <string name="info_perpetual_liquidation_price_title">Harga Pembubaran</string>
  <string name="info_perpetual_liquidation_price_description">Harga pembubaran ialah paras harga di mana kedudukan anda akan ditutup secara automatik untuk mengelakkan kerugian selanjutnya. Apabila harga pasaran mencapai tahap ini, kedudukan anda dibubarkan dan anda kehilangan margin anda.</string>
  <string name="info_perpetual_open_interest_title">Minat Terbuka</string>
  <string name="info_perpetual_open_interest_description">Faedah terbuka mewakili jumlah nilai semua kontrak kekal tertunggak yang belum dijelaskan. Ia memberikan pandangan tentang aktiviti pasaran dan kecairan.</string>
  <string name="info_no_quote_description">Tidak dapat mengembalikan sebut harga untuk pasangan token yang dipilih, mungkin disebabkan oleh jumlah yang rendah, kekurangan kecairan atau pengehadan teknikal.</string>
  <string name="info_stake_reserved_title">Dikhaskan untuk Yuran Rangkaian</string>
  <string name="info_stake_reserved_description">Sejumlah kecil kekal dalam dompet anda untuk menampung yuran untuk operasi seperti menanggalkan atau menuntut ganjaran.</string>
  <string name="info_stake_apr_description">Kadar Peratusan Tahunan (APR) ialah kadar ganjaran tahunan untuk mempertaruhkan mata wang kripto anda.</string>
  <string name="info_perpetual_auto_close_description">Tutup kedudukan anda secara automatik pada tahap harga yang ditetapkan. Ambil Untung mengunci keuntungan, Henti Kerugian menghadkan kerugian.</string>
  <string name="info_fully_diluted_valuation_title">Penilaian Dicairkan Sepenuhnya</string>
  <string name="info_fully_diluted_valuation_description">Nilai pasaran teori jika semua syiling berada dalam edaran. Dikira sebagai harga didarab dengan penawaran maksimum.</string>
  <string name="info_circulating_supply_description">Bilangan syiling yang kini tersedia dan didagangkan di pasaran.</string>
  <string name="info_total_supply_description">Jumlah syiling yang wujud, termasuk syiling yang dikunci atau ditempah.</string>
  <string name="info_max_supply_title">Bekalan Maks</string>
  <string name="info_max_supply_description">Bilangan maksimum syiling yang akan wujud.</string>
  <string name="info_perpetual_funding_apr_title">Pembiayaan APR</string>
  <string name="info_perpetual_funding_apr_description">Kadar tahunan di mana long membayar short (jika negatif, short membayar long). Tiada yuran yang berkaitan dengan pembiayaan, yang merupakan pemindahan rakan ke rakan antara pengguna untuk menolak harga ke arah harga spot.</string>
