  <string name="info_network_fee_title">עמלת רשת</string>
  <string name="info_watch_wallet_title">שעון ארנק</string>
  <string name="info_watch_wallet_description">ארנק שאין לך גישה אליו, אבל אתה יכול לצפות בעסקאות ובתנועות שלו.</string>
  <string name="info_network_fee_description">כל עסקה ברשת %1$s דורשת עמלה ב-%2$s ששולם לכורים על מנת לעבד את העסקה שלך, לא ארנק Gem. עמלות הרשת משתנות בהתאם לשימוש ברשת.</string>
  <string name="info_transaction_error_description">לא ניתן היה להשלים את העסקה עקב שגיאה, כגון חוסר כספים, קלט לא תקין או דחייה על ידי הרשת. אנא בדוק את הפרטים ונסה שוב.</string>
  <string name="info_transaction_pending_description">העסקה הוגשה וממתינה לאישור ברשת. זמני העיבוד עשויים להשתנות. אנא בדקו שוב לעדכונים.</string>
  <string name="info_transaction_success_description">העסקה הושלמה ואושרה ברשת. באפשרותך לעיין בפרטים כדי לאמת את מצבה.</string>
  <string name="info_lock_time_description">זמן הנעילה, המכונה גם תקופת ביטול ההצמדה או ההקפאה, הוא משך הזמן שבו נכסים בהימור אינם נגישים לאחר שהחלטת לבטל אותם.</string>
  <string name="info_price_impact_description">השפעת המחיר היא השינוי במחיר האסימון שנגרם על ידי גודל המסחר שלך. השפעה גבוהה יותר על המחיר פירושה שאתה מקבל פחות אסימונים עקב נזילות נמוכה או גודל הזמנה גדול.</string>
  <string name="info_slippage_description">החלקה (Slippage) מתייחסת להפרש בין המחיר הצפוי של עסקה לבין המחיר בפועל שבו היא מבוצעת.</string>
  <string name="info_asset_status_unverified_description">אסימונים שלא אומתו לא אומתו כראוי על ידי שירותי צד שלישי מהימנים. ייתכן שהם יופיעו בארנק שלך עקב הטלות אוויר, העברות או ייבוא ידני.</string>
  <string name="info_asset_status_suspicious_description">אסימונים חשודים או ספאם מזוהים כתרמיות פוטנציאליות או נכסים מזיקים. הם עשויים להופיע בארנק שלך עקב הטלות אוויר, העברות או ייבוא ידני.</string>
  <string name="info_insufficient_network_fee_balance_title">נדרש %1$s</string>
  <string name="info_insufficient_network_fee_balance_description">עסקה זו דורשת %1$s כדי לכסות את דמי הרשת ששולמו %2$s כורים, לא Gem Walletודא שיש לך מספיק %3$s.</string>
  <string name="info_insufficient_balance_title">יתרה לא מספקת</string>
  <string name="info_insufficient_balance_description">אין לך מספיק %1$s כדי להשלים עסקה זו. אנא טען, קבל או החלף בארנק שלך ונסה שוב.</string>
  <string name="info_account_minimum_balance_title">יתרה מינימלית</string>
  <string name="info_perpetual_funding_payments_title">מימון תשלומים</string>
  <string name="info_perpetual_funding_payments_description">תשלומי מימון הם תשלומים תקופתיים בין סוחרים כדי לשמור על מחיר החוזה התמידי קרוב למחיר הספוט של נכס הבסיס. מימון חיובי פירושו שפוזיציות ארוכות משלמות פוזיציות שורט, בעוד מימון שלילי פירושו פוזיציות שורט משלמות פוזיציות לונג.</string>
  <string name="info_perpetual_funding_rate_title">מימון</string>
  <string name="info_perpetual_funding_rate_description">שיעור המימון קובע את עלות החזקת פוזיציה נצחית. הוא מחושב לפי שעה ועוזר לשמור על שיווי משקל בין החוזה התמידי למחיר הספוט של נכס הבסיס.</string>
  <string name="info_perpetual_liquidation_price_title">מחיר פירוק</string>
  <string name="info_perpetual_liquidation_price_description">מחיר הפירוק הוא רמת המחיר שבה הפוזיציה שלך תיסגר אוטומטית כדי למנוע הפסדים נוספים. כאשר מחיר השוק מגיע לרמה זו, הפוזיציה שלך מחוסלת ואתה מאבד את המרווח שלך.</string>
  <string name="info_perpetual_open_interest_title">עניין פתוח</string>
  <string name="info_perpetual_open_interest_description">ריבית פתוחה מייצגת את הערך הכולל של כל החוזים התמידיים שטרם הוסדרו. הוא מספק תובנות לגבי פעילות השוק והנזילות.</string>
  <string name="info_no_quote_description">לא ניתן להחזיר הצעת מחיר עבור זוג האסימונים שנבחר, כנראה עקב סכום נמוך, חוסר נזילות או מגבלות טכניות.</string>
  <string name="info_stake_reserved_title">שמור עבור דמי רשת</string>
  <string name="info_stake_reserved_description">סכום קטן נשאר בארנק שלך כדי לכסות עמלות עבור פעולות כמו ביטול הפקדה או תביעת תגמולים.</string>
  <string name="info_stake_apr_description">שיעור אחוז שנתי (APR) הוא שיעור התגמול השנתי עבור הפקדת מטבע הקריפטו שלך.</string>
  <string name="info_perpetual_auto_close_description">סגור אוטומטית את הפוזיציה שלך ברמות מחיר קבועות. Take Profit נועל רווחים, Stop Loss מגביל הפסדים.</string>
  <string name="info_fully_diluted_valuation_title">הערכה מדוללת לחלוטין</string>
  <string name="info_fully_diluted_valuation_description">שווי השוק התיאורטי אם כל המטבעות היו במחזור. מחושב כמחיר כפול היצע מקסימלי.</string>
  <string name="info_circulating_supply_description">מספר המטבעות הזמינים ונסחרים כעת בשוק.</string>
  <string name="info_total_supply_description">המספר הכולל של מטבעות שקיימים, כולל מטבעות נעולים או שמורים.</string>
  <string name="info_max_supply_title">אספקה ​​מקסימלית</string>
