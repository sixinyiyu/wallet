"info.lock_time.description" = "Le temps de verrouillage, également connu sous le nom de période de déliement ou de dégel, est la durée pendant laquelle les actifs mis en jeu sont inaccessibles après que vous ayez décidé de les débloquer.";
"info.price_impact.description" = "L'impact sur le prix est la variation du prix du jeton causée par la taille de votre transaction. Un impact sur le prix plus élevé signifie que vous recevez moins de jetons en raison d'une faible liquidité ou d'une taille de commande importante.";
"info.slippage.description" = "Le glissement fait référence à la différence entre le prix attendu d'une transaction et le prix réel auquel elle est exécutée.";
"info.asset_status.unverified.description" = "Les jetons non vérifiés n'ont pas été suffisamment vérifiés par des services tiers de confiance. Ils peuvent apparaître dans votre portefeuille suite à des airdrops, des transferts ou des importations manuelles.";
"info.asset_status.suspicious.description" = "Les jetons suspects ou indésirables sont identifiés comme des arnaques potentielles ou des actifs dangereux. Ils peuvent apparaître dans votre portefeuille suite à des airdrops, des transferts ou des importations manuelles.";
"info.insufficient_network_fee_balance.title" = "%@ requis";
"info.insufficient_network_fee_balance.description" = "Cette transaction nécessite %@ pour couvrir les frais de réseau payés à %@ mineurs, pas Gem WalletAssurez-vous d'en avoir suffisamment %@.";
"info.insufficient_balance.title" = "Solde insuffisant";
"info.insufficient_balance.description" = "Vous n'avez pas assez de %@ pour finaliser cette transaction. Veuillez recharger, recevoir ou échanger votre portefeuille et réessayer.";
"info.account_minimum_balance.title" = "Solde minimum";
"info.perpetual.funding_payments.title" = "Paiements de financement";
"info.perpetual.funding_payments.description" = "Les paiements de financement sont des paiements périodiques entre traders visant à maintenir le prix du contrat perpétuel proche du prix au comptant de l'actif sous-jacent. Un financement positif signifie que les positions longues paient les positions courtes, tandis qu'un financement négatif signifie que les positions courtes paient les positions longues.";
"info.perpetual.funding_rate.title" = "Financement";
"info.perpetual.funding_rate.description" = "Le taux de financement détermine le coût de détention d'une position perpétuelle. Il est calculé toutes les heures et permet de maintenir l'équilibre de prix entre le contrat perpétuel et le prix spot de l'actif sous-jacent.";
"info.perpetual.liquidation_price.title" = "Prix de liquidation";
"info.perpetual.liquidation_price.description" = "Le prix de liquidation est le niveau de prix auquel votre position sera automatiquement fermée pour éviter de nouvelles pertes. Lorsque le prix du marché atteint ce niveau, votre position est liquidée et vous perdez votre marge.";
"info.perpetual.open_interest.title" = "Intérêt ouvert";
"info.perpetual.open_interest.description" = "Les intérêts ouverts représentent la valeur totale de tous les contrats perpétuels en cours qui n'ont pas été réglés. Il donne un aperçu de l'activité et de la liquidité du marché.";
"info.no_quote.description" = "Impossible de renvoyer un devis pour la paire de jetons sélectionnée, probablement en raison d'un faible montant, d'un manque de liquidité ou de limitations techniques.";
"info.stake.reserved.title" = "Réservé aux frais de réseau";
"info.stake.reserved.description" = "Une petite somme reste dans votre portefeuille pour couvrir les frais d'opérations telles que le déblocage ou la réclamation de récompenses.";
"info.stake.apr.description" = "Le taux annuel en pourcentage (APR) est le taux de récompense annuel pour le jalonnement de votre crypto-monnaie.";
"info.perpetual.auto_close.description" = "Clôturez automatiquement votre position à des niveaux de prix définis. Le Take Profit verrouille vos gains, tandis que le Stop Loss limite vos pertes.";
"info.fully_diluted_valuation.title" = "Évaluation entièrement diluée";
"info.fully_diluted_valuation.description" = "Valeur marchande théorique si toutes les pièces étaient en circulation. Calculée en multipliant le prix par l'offre maximale.";
"info.circulating_supply.description" = "Le nombre de pièces actuellement disponibles et échangées sur le marché.";
