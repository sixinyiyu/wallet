"info.asset_status.unverified.description" = "Tokeni ambazo hazijathibitishwa hazijathibitishwa vya kutosha na huduma zinazoaminika za wahusika wengine. Huenda zikaonekana kwenye mkoba wako kwa sababu ya matone ya hewa, uhamisho, au uagizaji wa mikono.";
"info.asset_status.suspicious.description" = "Tokeni zinazotiliwa shaka au taka zinatambuliwa kuwa ulaghai au mali hatari. Huenda zikaonekana kwenye mkoba wako kwa sababu ya matone ya hewa, uhamisho, au uagizaji wa mikono.";
"info.insufficient_network_fee_balance.title" = "%@ inahitajika";
"info.insufficient_network_fee_balance.description" = "Muamala huu unahitaji %@ ili kufidia ada ya mtandao iliyolipwa kwa %@ wachimbaji, si Gem WalletHakikisha una vya kutosha %@.";
"info.insufficient_balance.title" = "Mizani isiyotosha";
