"info.watch_wallet.title" = "Uhrenbrieftasche";
"info.watch_wallet.description" = "Eine Brieftasche, auf die Sie keinen Zugriff haben, deren Transaktionen und Bewegungen Sie jedoch beobachten können.";
"info.network_fee.description" = "Für jede Transaktion im %@-Netzwerk wird eine Gebühr in %@ an die Miner gezahlt, um Ihre Transaktion abzuwickeln, nicht an Gem Wallet. Die Netzwerkgebühren variieren je nach Netzwerknutzung.";
"info.transaction.error.description" = "Die Transaktion konnte aufgrund eines Fehlers nicht abgeschlossen werden, z. B. aufgrund unzureichender Mittel, ungültiger Eingaben oder einer Ablehnung durch das Netzwerk. Bitte überprüfen Sie die Details und versuchen Sie es erneut.";
"info.transaction.pending.description" = "Die Transaktion wurde übermittelt und wartet auf die Bestätigung im Netzwerk. Die Bearbeitungszeit kann variieren. Bitte schauen Sie später noch einmal vorbei, um Updates zu erhalten.";
"info.transaction.success.description" = "Die Transaktion wurde abgeschlossen und im Netzwerk bestätigt. Sie können die Details überprüfen, um den Status zu verifizieren.";
"info.lock_time.description" = "Die Sperrzeit, auch Unbonding- oder Unfreezing-Zeitraum genannt, ist der Zeitraum, in dem abgesteckte Vermögenswerte nicht mehr zugänglich sind, nachdem Sie sich entschieden haben, sie aufzuheben.";
"info.price_impact.description" = "Der Preiseinfluss ist die Änderung des Token-Preises, die durch Ihre Handelsgröße verursacht wird. Ein höherer Preiseinfluss bedeutet, dass Sie aufgrund geringer Liquidität oder einer großen Auftragsgröße weniger Token erhalten.";
"info.slippage.description" = "Slippage bezeichnet die Differenz zwischen dem erwarteten Preis eines Handels und dem tatsächlichen Preis, zu dem er ausgeführt wird.";
"info.asset_status.unverified.description" = "Nicht verifizierte Token wurden von vertrauenswürdigen Drittanbietern nicht ausreichend verifiziert. Sie können aufgrund von Airdrops, Transfers oder manuellen Importen in Ihrem Wallet erscheinen.";
"info.asset_status.suspicious.description" = "Verdächtige oder Spam-Token werden als potenzieller Betrug oder schädliche Vermögenswerte identifiziert. Sie können aufgrund von Airdrops, Transfers oder manuellen Importen in Ihrer Wallet erscheinen.";
"info.insufficient_network_fee_balance.title" = "%@ erforderlich";
"info.insufficient_network_fee_balance.description" = "Für diese Transaktion ist Folgendes erforderlich %@ um die Netzwerkgebühr zu decken, die an %@ Bergleute, nicht Gem WalletStellen Sie sicher, dass Sie genügend haben. %@Die";
"info.insufficient_balance.title" = "Unzureichendes Guthaben";
"info.insufficient_balance.description" = "Sie haben nicht genügend %@, um diese Transaktion abzuschließen. Bitte laden Sie Ihr Wallet auf, empfangen Sie es oder tauschen Sie es um und versuchen Sie es erneut.";
"info.account_minimum_balance.title" = "Mindestguthaben";
"info.perpetual.funding_payments.title" = "Finanzierungszahlungen";
"info.perpetual.funding_payments.description" = "Finanzierungszahlungen sind regelmäßige Zahlungen zwischen Händlern, um den Preis des unbefristeten Vertrags nahe am Spotpreis des zugrunde liegenden Vermögenswerts zu halten. Positive Finanzierung bedeutet, dass Long-Positionen Short-Positionen bezahlen, während negative Finanzierung bedeutet, dass Short-Positionen Long-Positionen bezahlen.";
"info.perpetual.funding_rate.title" = "Finanzierung";
"info.perpetual.funding_rate.description" = "Der Finanzierungssatz bestimmt die Kosten für das Halten einer unbefristeten Position. Er wird stündlich berechnet und trägt dazu bei, das Preisgleichgewicht zwischen dem unbefristeten Vertrag und dem Kassapreis des Basiswerts aufrechtzuerhalten.";
"info.perpetual.liquidation_price.title" = "Liquidationspreis";
"info.perpetual.liquidation_price.description" = "Der Liquidationspreis ist das Preisniveau, bei dem Ihre Position automatisch geschlossen wird, um weitere Verluste zu verhindern. Wenn der Marktpreis dieses Niveau erreicht, wird Ihre Position liquidiert und Sie verlieren Ihre Marge.";
"info.perpetual.open_interest.title" = "Offenes Interesse";
"info.perpetual.open_interest.description" = "Das offene Interesse stellt den Gesamtwert aller ausstehenden unbefristeten Verträge dar, die noch nicht abgewickelt wurden. Es bietet Einblick in die Marktaktivität und Liquidität.";
"info.no_quote.description" = "Für das ausgewählte Token-Paar kann kein Angebot zurückgegeben werden, möglicherweise aufgrund eines geringen Betrags, mangelnder Liquidität oder technischer Einschränkungen.";
"info.stake.reserved.title" = "Reserviert für Netzwerkgebühr";
"info.stake.reserved.description" = "Ein kleiner Betrag verbleibt in Ihrem Wallet, um Gebühren für Vorgänge wie das Aufheben der Absteckung oder das Einfordern von Prämien zu decken.";
"info.stake.apr.description" = "Der effektive Jahreszins (APR) ist der jährliche Belohnungssatz für das Staking Ihrer Kryptowährung.";
"info.perpetual.auto_close.description" = "Schließen Sie Ihre Position automatisch bei festgelegten Preisniveaus. Take Profit sichert Gewinne, Stop Loss begrenzt Verluste.";
"info.fully_diluted_valuation.title" = "Vollständig verwässerte Bewertung";
"info.fully_diluted_valuation.description" = "Der theoretische Marktwert, wenn alle Münzen im Umlauf wären. Berechnet als Preis multipliziert mit der maximalen Gesamtmenge.";
"info.circulating_supply.description" = "Die Anzahl der aktuell verfügbaren und auf dem Markt gehandelten Coins.";
"info.total_supply.description" = "Die Gesamtzahl der existierenden Münzen, einschließlich gesperrter oder reservierter Münzen.";
"info.max_supply.title" = "Maximale Versorgung";
"info.max_supply.description" = "Die maximale Anzahl an Münzen, die jemals existieren wird.";
"info.perpetual.funding_apr.title" = "Finanzierung effektiver Jahreszins";
"info.perpetual.funding_apr.description" = "Der auf das Jahr umgerechnete Zinssatz, zu dem Long-Positionen Short-Positionen zahlen (bei negativem Wert zahlen Short-Positionen Long-Positionen). Mit der Finanzierung sind keine Gebühren verbunden, es handelt sich um einen Peer-to-Peer-Transfer zwischen Nutzern, um die Preise in Richtung des Spotpreises zu drücken.";
"info.minimum_amount.title" = "Mindestbetrag";
"info.minimum_amount.description" = "Im %@-Netzwerk beträgt der Mindestbetrag für diese Transaktion %@.";
"input.enter_amount_to" = "Bitte geben Sie den Betrag %@ ein.";
