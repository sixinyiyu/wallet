"info.watch_wallet.title" = "Guarda Portafoglio";
"info.watch_wallet.description" = "Un portafoglio a cui non hai accesso, ma di cui puoi monitorare le transazioni e i movimenti.";
"info.network_fee.description" = "Ogni transazione sulla rete %@ richiede una commissione in %@ pagata ai minatori per elaborare la transazione, non a Gem Wallet. Le tariffe di rete variano in base all'utilizzo della rete.";
"info.transaction.error.description" = "La transazione non è stata completata a causa di un errore, ad esempio fondi insufficienti, input non validi o rifiuto da parte della rete. Si prega di controllare i dettagli e riprovare.";
"info.transaction.pending.description" = "La transazione è stata inoltrata ed è in attesa di conferma sulla rete. I tempi di elaborazione possono variare. Si prega di controllare regolarmente per aggiornamenti.";
"info.transaction.success.description" = "La transazione è stata completata e confermata sulla rete. Puoi controllare i dettagli per verificarne lo stato.";
"info.lock_time.description" = "Il tempo di blocco, noto anche come periodo di svincolo o sblocco, è la durata durante la quale le risorse vincolate sono inaccessibili dopo che hai deciso di rimuoverle.";
"info.price_impact.description" = "L'impatto sul prezzo è la variazione del prezzo del token causata dalla dimensione del tuo trade. Un impatto sul prezzo più elevato significa che ricevi meno token a causa della bassa liquidità o di una grande dimensione dell'ordine.";
"info.slippage.description" = "Lo slippage si riferisce alla differenza tra il prezzo previsto di una transazione e il prezzo effettivo a cui viene eseguita.";
"info.asset_status.unverified.description" = "I token non verificati non sono stati sufficientemente verificati da servizi di terze parti affidabili. Potrebbero comparire nel tuo portafoglio a causa di airdrop, trasferimenti o importazioni manuali.";
"info.asset_status.suspicious.description" = "I token sospetti o spam vengono identificati come potenziali truffe o asset dannosi. Potrebbero comparire nel tuo portafoglio a seguito di airdrop, trasferimenti o importazioni manuali.";
"info.insufficient_network_fee_balance.title" = "%@ richiesto";
"info.insufficient_network_fee_balance.description" = "Questa transazione richiede %@ per coprire la quota di rete pagata a %@ minatori, non Gem WalletAssicurati di averne abbastanza %@.";
"info.insufficient_balance.title" = "Saldo insufficiente";
"info.insufficient_balance.description" = "Non hai abbastanza %@ per completare questa transazione. Ricarica, ricevi o scambia nel tuo portafoglio e riprova.";
"info.account_minimum_balance.title" = "Saldo minimo";
"info.perpetual.funding_payments.title" = "Pagamenti di finanziamento";
"info.perpetual.funding_payments.description" = "I pagamenti di finanziamento sono pagamenti periodici tra trader per mantenere il prezzo del contratto perpetuo vicino al prezzo spot dell'attività sottostante. Un finanziamento positivo significa che le posizioni lunghe pagano le posizioni corte, mentre un finanziamento negativo significa che le posizioni corte pagano le posizioni lunghe.";
"info.perpetual.funding_rate.title" = "Finanziamento";
"info.perpetual.funding_rate.description" = "Il tasso di finanziamento determina il costo di mantenimento di una posizione perpetua. Viene calcolato su base oraria e aiuta a mantenere l'equilibrio dei prezzi tra il contratto perpetuo e il prezzo spot dell'attività sottostante.";
"info.perpetual.liquidation_price.title" = "Prezzo di liquidazione";
"info.perpetual.liquidation_price.description" = "Il prezzo di liquidazione è il livello di prezzo al quale la tua posizione verrà chiusa automaticamente per evitare ulteriori perdite. Quando il prezzo di mercato raggiunge questo livello, la tua posizione viene liquidata e perdi il tuo margine.";
"info.perpetual.open_interest.title" = "Interesse aperto";
"info.perpetual.open_interest.description" = "L'interesse aperto rappresenta il valore totale di tutti i contratti perpetui in essere che non sono stati regolati. Fornisce informazioni sull'attività del mercato e sulla liquidità.";
"info.no_quote.description" = "Impossibile restituire una quotazione per la coppia di token selezionata, probabilmente a causa dell'importo basso, della mancanza di liquidità o di limitazioni tecniche.";
"info.stake.reserved.title" = "Riservato per la commissione di rete";
"info.stake.reserved.description" = "Una piccola somma rimane nel tuo portafoglio per coprire le commissioni per operazioni come l'annullamento dello staking o la richiesta di premi.";
"info.stake.apr.description" = "Il tasso percentuale annuo (APR) è il tasso di ricompensa annuale per lo staking della tua criptovaluta.";
"info.perpetual.auto_close.description" = "Chiudi automaticamente la tua posizione a livelli di prezzo prestabiliti. Il Take Profit blocca i guadagni, mentre lo Stop Loss limita le perdite.";
"info.fully_diluted_valuation.title" = "Valutazione completamente diluita";
"info.fully_diluted_valuation.description" = "Valore di mercato teorico se tutte le monete fossero in circolazione. Calcolato come prezzo moltiplicato per l'offerta massima.";
"info.circulating_supply.description" = "Il numero di monete attualmente disponibili e scambiate sul mercato.";
"info.total_supply.description" = "Il numero totale di monete esistenti, comprese quelle bloccate o riservate.";
"info.max_supply.title" = "Massima fornitura";
"info.max_supply.description" = "Il numero massimo di monete che esisteranno mai.";
"info.perpetual.funding_apr.title" = "Finanziamento APR";
"info.perpetual.funding_apr.description" = "Il tasso annualizzato al quale le posizioni long pagano le posizioni short (se negativo, le posizioni short pagano le posizioni long). Non sono previste commissioni associate al finanziamento, che è un trasferimento peer-to-peer tra utenti per spingere i prezzi verso il prezzo spot.";
"info.minimum_amount.title" = "Importo minimo";
"info.minimum_amount.description" = "Sulla rete %@, l'importo minimo per questa transazione è %@.";
