"info.network_fee.title" = "Tarifa de red";
"info.watch_wallet.title" = "Cartera de reloj";
"info.watch_wallet.description" = "Una billetera a la que no tienes acceso, pero puedes observar sus transacciones y movimientos.";
"info.network_fee.description" = "Cada transacción en la red %@ requiere una tarifa en %@ pagada a los mineros para procesar su transacción, no a Gem Wallet. Las tarifas de red varían según el uso de la red.";
"info.transaction.error.description" = "La transacción no se pudo completar debido a un error, como fondos insuficientes, una entrada no válida o un rechazo de la red. Revise los detalles y vuelva a intentarlo.";
"info.transaction.pending.description" = "La transacción se ha enviado y está pendiente de confirmación en la red. El tiempo de procesamiento puede variar. Por favor, vuelva a consultar para obtener actualizaciones.";
"info.transaction.success.description" = "La transacción se ha completado y confirmado en la red. Puedes revisar los detalles para verificar su estado.";
"info.lock_time.description" = "El tiempo de bloqueo, también conocido como período de desvinculación o descongelación, es el período durante el cual los activos apostados son inaccesibles después de que usted decide cancelar su participación.";
"info.price_impact.description" = "El impacto en el precio es el cambio en el precio del token causado por el tamaño de la operación. Un mayor impacto en el precio significa que recibe menos tokens debido a una baja liquidez o a un gran tamaño de la orden.";
"info.slippage.description" = "El deslizamiento se refiere a la diferencia entre el precio esperado de una operación y el precio real al que se ejecuta.";
"info.asset_status.unverified.description" = "Los tokens no verificados no han sido verificados adecuadamente por servicios externos de confianza. Podrían aparecer en tu billetera debido a airdrops, transferencias o importaciones manuales.";
"info.asset_status.suspicious.description" = "Los tokens sospechosos o spam se identifican como posibles estafas o activos dañinos. Pueden aparecer en tu billetera debido a airdrops, transferencias o importaciones manuales.";
"info.insufficient_network_fee_balance.title" = "%@ requerido";
"info.insufficient_network_fee_balance.description" = "Esta transacción requiere %@ para cubrir la tarifa de red pagada a %@ mineros, no Gem WalletAsegúrese de tener suficiente %@.";
"info.insufficient_balance.title" = "Saldo insuficiente";
"info.insufficient_balance.description" = "No tienes suficientes %@ para completar esta transacción. Recarga, recibe o intercambia tu billetera y vuelve a intentarlo.";
"info.account_minimum_balance.title" = "Saldo mínimo";
"info.perpetual.funding_payments.title" = "Pagos de financiación";
"info.perpetual.funding_payments.description" = "Los pagos de financiación son pagos periódicos entre comerciantes para mantener el precio del contrato perpetuo cerca del precio al contado del activo subyacente. La financiación positiva significa que las posiciones largas pagan posiciones cortas, mientras que la financiación negativa significa que las posiciones cortas pagan posiciones largas.";
"info.perpetual.funding_rate.title" = "Financiamiento";
"info.perpetual.funding_rate.description" = "La tasa de financiación determina el costo de mantener una posición perpetua. Se calcula cada hora y ayuda a mantener el equilibrio de precios entre el contrato perpetuo y el precio al contado del activo subyacente.";
"info.perpetual.liquidation_price.title" = "Precio de liquidación";
"info.perpetual.liquidation_price.description" = "El precio de liquidación es el nivel de precio en el que su posición se cerrará automáticamente para evitar mayores pérdidas. Cuando el precio de mercado alcanza este nivel, su posición se liquida y pierde su margen.";
"info.perpetual.open_interest.title" = "Interés abierto";
"info.perpetual.open_interest.description" = "El interés abierto representa el valor total de todos los contratos perpetuos pendientes que no se han liquidado. Proporciona información sobre la actividad y la liquidez del mercado.";
"info.no_quote.description" = "No se puede devolver una cotización para el par de tokens seleccionado, posiblemente debido a una cantidad baja, falta de liquidez o limitaciones técnicas.";
"info.stake.reserved.title" = "Reservado para comisión de red";
"info.stake.reserved.description" = "Una pequeña cantidad permanece en tu billetera para cubrir las tarifas de operaciones como dejar de apostar o reclamar recompensas.";
"info.stake.apr.description" = "La tasa de porcentaje anual (APR) es la tasa de recompensa anual por apostar su criptomoneda.";
"info.perpetual.auto_close.description" = "Cierra tu posición automáticamente a precios establecidos. El Take Profit fija las ganancias y el Stop Loss limita las pérdidas.";
"info.fully_diluted_valuation.title" = "Valoración totalmente diluida";
"info.fully_diluted_valuation.description" = "El valor teórico de mercado si todas las monedas estuvieran en circulación. Se calcula multiplicando el precio por la oferta máxima.";
"info.circulating_supply.description" = "La cantidad de monedas actualmente disponibles y comercializadas en el mercado.";
"info.total_supply.description" = "El número total de monedas que existen, incluidas las monedas bloqueadas o reservadas.";
"info.max_supply.title" = "Suministro máximo";
"info.max_supply.description" = "El número máximo de monedas que jamás existirán.";
"info.perpetual.funding_apr.title" = "TAE de financiación";
"info.perpetual.funding_apr.description" = "La tasa anualizada a la que los largos pagan a los cortos (si es negativa, los cortos pagan a los largos). No hay tarifas asociadas con la financiación, que es una transferencia de igual a igual entre usuarios para impulsar los precios hacia el precio al contado.";
"info.minimum_amount.title" = "Cantidad Mínima";
"info.minimum_amount.description" = "En la red %@, el importe mínimo para esta transacción es %@.";
"input.enter_amount_to" = "Por favor ingrese la cantidad a %@";
