"info.lock_time.description" = "Час блокування, також відомий як період розблокування або розморожування, — це тривалість, протягом якої ставлені активи недоступні після того, як ви вирішили їх скасувати.";
"info.price_impact.description" = "Вплив ціни — це зміна ціни токена, спричинена розміром вашої торгівлі. Більший вплив на ціну означає, що ви отримуєте менше токенів через низьку ліквідність або великий розмір замовлення.";
"info.slippage.description" = "Прослизання стосується різниці між очікуваною ціною угоди та фактичною ціною, за якою вона виконується.";
"info.asset_status.unverified.description" = "Неперевірені токени не були достатньо перевірені надійними сторонніми сервісами. Вони можуть з'явитися у вашому гаманці через аїрдропи, перекази або ручний імпорт.";
"info.asset_status.suspicious.description" = "Підозрілі або спам-токени ідентифікуються як потенційні шахрайські або шкідливі активи. Вони можуть з'явитися у вашому гаманці через аїрдропи, перекази або ручний імпорт.";
"info.insufficient_network_fee_balance.title" = "Потрібно %@";
"info.insufficient_network_fee_balance.description" = "Ця транзакція вимагає %@ для покриття мережевої комісії, що виплачується майнерам %@ , а не Gem Wallet. Переконайтеся, що у вас достатньо %@.";
"info.insufficient_balance.title" = "Недостатній баланс";
"info.insufficient_balance.description" = "У вас недостатньо %@ для завершення цієї транзакції. Будь ласка, поповніть, отримайте або обміняйте свій гаманець і спробуйте ще раз.";
"info.account_minimum_balance.title" = "Мінімальний баланс";
"info.perpetual.funding_payments.title" = "Фінансування платежів";
"info.perpetual.funding_payments.description" = "Платежі фінансування — це періодичні платежі між трейдерами, щоб підтримувати постійну ціну контракту близькою до спотової ціни базового активу. Позитивне фінансування означає, що довгі позиції оплачують короткі позиції, тоді як негативне фінансування означає, що короткі позиції оплачують довгі позиції.";
"info.perpetual.funding_rate.title" = "Фінансування";
"info.perpetual.funding_rate.description" = "Ставка фінансування визначає вартість утримання безстрокової посади. Він розраховується щогодини та допомагає підтримувати цінову рівновагу між безстроковим контрактом і спотовою ціною базового активу.";
"info.perpetual.liquidation_price.title" = "Ліквідаційна ціна";
"info.perpetual.liquidation_price.description" = "Ліквідаційна ціна – це рівень ціни, на якому ваша позиція буде автоматично закрита, щоб запобігти подальшим втратам. Коли ринкова ціна досягає цього рівня, ваша позиція ліквідується, і ви втрачаєте маржу.";
"info.perpetual.open_interest.title" = "Відкритий інтерес";
"info.perpetual.open_interest.description" = "Відкритий інтерес представляє собою загальну вартість усіх незавершених безстрокових контрактів, які не були розраховані. Він дає уявлення про ринкову активність і ліквідність.";
"info.no_quote.description" = "Неможливо повернути котирування для вибраної пари токенів, можливо через низьку кількість, брак ліквідності або технічні обмеження.";
"info.stake.reserved.title" = "Зарезервовано для комісії мережі";
"info.stake.reserved.description" = "Невелика сума залишається у вашому гаманці для покриття комісій за такі операції, як зняття коштів зі стейкінгу або отримання винагород.";
"info.stake.apr.description" = "Річна процентна ставка (APR) – це річна ставка винагороди за стейкінг вашої криптовалюти.";
"info.perpetual.auto_close.description" = "Автоматично закривайте свою позицію за встановленими ціновими рівнями. Тейк-профіт фіксує прибутки, а стоп-лос обмежує збитки.";
"info.fully_diluted_valuation.title" = "Повністю розбавлена оцінка";
"info.fully_diluted_valuation.description" = "Теоретична ринкова вартість, якби всі монети були в обігу. Розраховується як ціна, помножена на максимальну пропозицію.";
"info.circulating_supply.description" = "Кількість монет, що наразі доступні та торгуються на ринку.";
"info.total_supply.description" = "Загальна кількість існуючих монет, включаючи заблоковані або зарезервовані монети.";
"info.max_supply.title" = "Максимальна пропозиція";
"info.max_supply.description" = "Максимальна кількість монет, яка коли-небудь існуватиме.";
"info.perpetual.funding_apr.title" = "Фінансування річних";
"info.perpetual.funding_apr.description" = "Річна ставка, за якою довгі позиції платять за короткі позиції (якщо від'ємна, короткі позиції платять за довгі позики). Немає жодної комісії, пов'язаної з фінансуванням, яке є одноранговою передачею між користувачами для підвищення цін до спотової ціни.";
