"info.perpetual.funding_payments.title" = "Financieringsbetalingen";
"info.perpetual.funding_payments.description" = "Financieringsbetalingen zijn periodieke betalingen tussen handelaren om de eeuwigdurende contractprijs dicht bij de spotprijs van de onderliggende waarde te houden. Positieve financiering betekent dat longposities shortposities betalen, terwijl negatieve financiering betekent dat shortposities longposities betalen.";
"info.perpetual.funding_rate.title" = "Financiering";
"info.perpetual.funding_rate.description" = "Het financieringspercentage bepaalt de kosten voor het aanhouden van een eeuwigdurende positie. Het wordt elk uur berekend en helpt het prijsevenwicht tussen het eeuwigdurende contract en de spotprijs van de onderliggende waarde te handhaven.";
"info.perpetual.liquidation_price.title" = "Liquidatieprijs";
